---
// BaseLayout.astro — shared <head> for every page
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  bodyClass?: string;
  bodyDataPage?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogUrl = 'https://jainanurag.me',
  ogImage = 'https://jainanurag.me/images/og-image.png',
  bodyDataPage,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500;700&family=Bricolage+Grotesque:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Page-specific styles injected by child layouts -->
    <slot name="head" />

    <!-- Theme toggle styles -->
    <style>
      .theme-toggle {
        position: fixed;
        top: 18px;
        right: 18px;
        z-index: 1000;
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        border: 1px solid var(--border-accent);
        background: var(--surface-overlay);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: var(--text-primary);
        font-size: 1.15rem;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.2s, background 0.2s;
        padding: 0;
        line-height: 1;
      }
      .theme-toggle:hover {
        border-color: var(--accent);
        transform: scale(1.08);
      }
      .theme-toggle svg { width: 20px; height: 20px; transition: opacity 0.2s, transform 0.3s; }
      .theme-toggle .icon-sun,
      .theme-toggle .icon-moon { position: absolute; }
      .theme-toggle .icon-sun { opacity: 0; transform: rotate(-90deg) scale(0.5); }
      .theme-toggle .icon-moon { opacity: 1; transform: rotate(0) scale(1); }
      [data-theme="light"] .theme-toggle .icon-sun { opacity: 1; transform: rotate(0) scale(1); }
      [data-theme="light"] .theme-toggle .icon-moon { opacity: 0; transform: rotate(90deg) scale(0.5); }

      /* Toggle spin animation */
      @keyframes togglePop {
        0%   { transform: scale(1)    rotate(0deg); }
        40%  { transform: scale(1.18) rotate(180deg); }
        100% { transform: scale(1)    rotate(360deg); }
      }
      .theme-toggle.toggling {
        animation: togglePop 0.38s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      }

      /* View Transitions crossfade */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.3s;
        animation-timing-function: ease;
      }
    </style>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        if (!saved) {
          saved = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        if (saved === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body data-page={bodyDataPage}>
    <!-- Theme toggle -->
    <button class="theme-toggle" aria-label="Toggle theme" type="button">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>

    <slot />
    <script src="/scripts/main.js" is:inline></script>
    <script is:inline>
      (function() {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'light' ? 'dark' : 'light';

          // Button spin
          btn.classList.add('toggling');
          btn.addEventListener('animationend', function() {
            btn.classList.remove('toggling');
          }, { once: true });

          function applyTheme() {
            if (next === 'dark') {
              document.documentElement.removeAttribute('data-theme');
            } else {
              document.documentElement.setAttribute('data-theme', 'light');
            }
            localStorage.setItem('theme', next);
          }

          // Smooth page crossfade via View Transitions (Chrome 111+, Safari 18+)
          if (document.startViewTransition) {
            document.startViewTransition(applyTheme);
          } else {
            applyTheme();
          }
        });
      })();
    </script>
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "99033085f37f45f48f42683439e0f638"}'></script>
  </body>
</html>
